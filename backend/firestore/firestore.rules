rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function role() { return request.auth.token.role; }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow read: if role() == "admin";
    }

    match /products/{productId} {
      allow read: if true; // public catalog
      allow write: if isSignedIn() && (role() == "shopOwner" || role() == "admin");
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read, update: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || role() == "admin" || role() == "delivery");
    }

    match /categories/{docId} { allow read: if true; allow write: if role() == "admin"; }
    match /addresses/{docId} { allow read, write: if isSignedIn() && resource.data.userId == request.auth.uid; }
    match /cart/{docId} { allow read, write: if isSignedIn() && resource.data.userId == request.auth.uid; }
    match /notifications/{docId} { allow read: if isSignedIn(); allow write: if role() == "admin"; }
    match /deliveryPartners/{docId} { allow read: if isSignedIn(); allow write: if role() == "admin"; }
    match /shops/{docId} { allow read: if true; allow write: if role() == "shopOwner" || role() == "admin"; }
    match /offers/{docId} { allow read: if true; allow write: if role() == "admin"; }
    match /wishlist/{docId} { allow read, write: if isSignedIn() && resource.data.userId == request.auth.uid; }
    match /reviews/{docId} { allow read: if true; allow create: if isSignedIn(); }
  }
}
