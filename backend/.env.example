# Server
PORT=10000
NODE_ENV=production
CORS_ORIGIN=*

# Firebase Admin (service account JSON, base64-encoded as a single line)
# Generate with: base64 -w0 serviceAccountKey.json  (Linux)  |  base64 serviceAccountKey.json (Mac)
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Google Maps (used by backend for distance/ETA calculations, optional)
GOOGLE_MAPS_API_KEY=
