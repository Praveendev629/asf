# ============================================================
# API APP (deploy to Vercel - root dir: api)
# ============================================================
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/asf-shopee
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
CLOUDINARY_CLOUD_NAME=xxx
CLOUDINARY_API_KEY=xxx
CLOUDINARY_API_SECRET=xxx
DELIVERY_JWT_SECRET=any-random-secret-string
ADMIN_EMAILS=you@example.com

# ============================================================
# WEBSITE APP (deploy to Vercel - root dir: website)
# ============================================================
NEXT_PUBLIC_API_URL=https://asf-api-five.vercel.app
NEXT_PUBLIC_FIREBASE_API_KEY=xxx
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=xxx.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=xxx
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=xxx.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=xxx
NEXT_PUBLIC_FIREBASE_APP_ID=xxx
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=xxx
NEXT_PUBLIC_ADMIN_URL=https://your-admin.vercel.app
NEXT_PUBLIC_ADMIN_EMAILS=you@example.com

# ============================================================
# ADMIN APP (deploy to Vercel - root dir: admin)
# ============================================================
NEXT_PUBLIC_API_URL=https://asf-api-five.vercel.app

# ============================================================
# DELIVERY APP (deploy to Vercel - root dir: delivery)
# ============================================================
NEXT_PUBLIC_API_URL=https://asf-api-five.vercel.app
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=xxx

# ============================================================
# MOBILE APP (Expo)
# ============================================================
EXPO_PUBLIC_API_URL=https://asf-api-five.vercel.app
EXPO_PUBLIC_FIREBASE_WEB_CLIENT_ID=xxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxx.apps.googleusercontent.com
