# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/asf-shopee

# Firebase (client — from Firebase Console > Project Settings > General)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server — Project Settings > Service Accounts > Generate new private key)
# Paste the ENTIRE JSON file contents as one line, or base64-encode it first.
FIREBASE_SERVICE_ACCOUNT_KEY=

# Cloudinary (Dashboard > Account Details)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Comma-separated list of emails allowed to access /admin
ADMIN_EMAILS=you@example.com
# Same list exposed to the client so the Admin nav link shows correctly
NEXT_PUBLIC_ADMIN_EMAILS=you@example.com
