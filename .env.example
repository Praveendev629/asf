# MongoDB (used by API app)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/asf-shopee

# Firebase (customer auth - used by website app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server - used by API app)
FIREBASE_SERVICE_ACCOUNT_KEY=

# Cloudinary (used by API app)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Maps API Key (used by website + delivery apps)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# JWT Secret for delivery partner auth (used by API app)
DELIVERY_JWT_SECRET=change-this-to-a-random-string

# API URL (used by website, admin, delivery apps to call the API)
NEXT_PUBLIC_API_URL=https://your-api-app.vercel.app

# Admin website URL (shown in customer navbar)
NEXT_PUBLIC_ADMIN_URL=https://your-admin-app.vercel.app

# Admin emails (for navbar display only)
ADMIN_EMAILS=you@example.com
NEXT_PUBLIC_ADMIN_EMAILS=you@example.com
