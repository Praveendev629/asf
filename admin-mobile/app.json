{
  "expo": {
    "name": "ASF Admin",
    "slug": "asf-admin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#059669"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.asf.admin"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#059669"
      },
      "package": "com.asf.admin"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#059669"
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "apiUrl": "https://asf-api-five.vercel.app",
      "eas": {
        "projectId": "f740a377-ca1f-432c-b590-192cad947c7e"
      }
    },
    "owner": "praveenseenu6289"
  }
}
