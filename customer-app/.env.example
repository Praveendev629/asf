# Copy this file to `.env` in this folder and fill in real values.
# `.env` is loaded by app.config.js via the `dotenv` package for local dev
# (`npx expo start`). For EAS builds, set the same names as EAS secrets:
#   eas secret:create --name FIREBASE_API_KEY --value "..."

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Backend API deployed on Render, e.g. https://asf-shopee-backend.onrender.com/api
API_BASE_URL=http://localhost:10000/api

GOOGLE_MAPS_API_KEY=

RAZORPAY_KEY_ID=

# Optional: your EAS project id (from `eas init`), used for push notifications
EAS_PROJECT_ID=
